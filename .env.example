# Copy to .env and keep the real values local.
# Never commit real API keys or tokens.

# Default TTS provider (Gradium)
GRADIUM_API_KEY=
GRADIUM_VOICE_ID=

# Second TTS provider (Cartesia)
CARTESIA_API_KEY=
CARTESIA_VOICE_ID=

# Optional provider selection (CLI --provider overrides this)
# UBIKIA_TTS_PROVIDER=gradium
# UBIKIA_TTS_FALLBACK_PROVIDERS=cartesia

# Optional overrides
# GRADIUM_TTS_URL=https://api.gradium.ai/api/post/speech/tts
# CARTESIA_TTS_URL=https://api.cartesia.ai/tts/bytes
# CARTESIA_API_VERSION=2026-03-01
# CARTESIA_MODEL=sonic-3.5
# CARTESIA_SAMPLE_RATE=44100
# CARTESIA_LANGUAGE=fr
# UBIKIA_AUDIO_FORMAT=wav
# UBIKIA_AUDIO_LANGUAGE=fr
