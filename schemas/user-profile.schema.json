{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ubikia.example/schemas/user-profile.schema.json",
  "title": "Ubikia user profile",
  "type": "object",
  "required": [
    "schema",
    "account",
    "displayName",
    "defaultLanguage",
    "publicationPolicy"
  ],
  "properties": {
    "schema": {
      "const": "ubikia.user-profile.v0.1"
    },
    "account": {
      "type": "string",
      "minLength": 1
    },
    "displayName": {
      "type": "string",
      "minLength": 1
    },
    "defaultLanguage": {
      "type": "string",
      "minLength": 2
    },
    "instructionFiles": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "audio": {
      "type": "object",
      "properties": {
        "defaultProvider": {
          "type": ["string", "null"]
        },
        "voiceReference": {
          "type": ["string", "null"]
        },
        "syntheticVoiceDisclosure": {
          "type": ["string", "null"]
        },
        "defaultFormats": {
          "type": "array",
          "items": {
            "enum": ["wav", "mp3", "opus", "pcm"]
          },
          "uniqueItems": true
        }
      },
      "additionalProperties": true
    },
    "series": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*$"
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "language": {
            "type": ["string", "null"]
          },
          "author": {
            "type": ["string", "null"]
          },
          "writtenPlatform": {
            "type": ["string", "null"]
          },
          "audioPlatform": {
            "type": ["string", "null"]
          },
          "defaultVisibility": {
            "enum": ["private", "unlisted", "public"]
          }
        },
        "additionalProperties": true
      }
    },
    "publicationPolicy": {
      "type": "object",
      "required": [
        "humanReviewRequired",
        "automaticPublicPublicationAllowed"
      ],
      "properties": {
        "humanReviewRequired": {
          "type": "boolean"
        },
        "automaticPublicPublicationAllowed": {
          "type": "boolean"
        },
        "firstUploadVisibility": {
          "enum": ["private", "unlisted", "public"]
        },
        "sourceLinkRequired": {
          "type": "boolean"
        },
        "syntheticVoiceDisclosureRequired": {
          "type": "boolean"
        }
      },
      "additionalProperties": true
    },
    "secretReferences": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "pattern": "^(env|secret|credential):"
      }
    },
    "extensions": {
      "type": "object"
    }
  },
  "additionalProperties": true
}
